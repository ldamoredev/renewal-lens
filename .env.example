# Required from Phase 2 onward for live screenshot analysis. Server-side only.
ANTHROPIC_API_KEY=

# Extraction model. Defaults to claude-haiku-4-5 (Phase 2 decision: the
# cheapest current model with vision and structured-output support).
ANTHROPIC_MODEL=claude-haiku-4-5

# Railway injects PORT at runtime. Do not hard-code it here.
